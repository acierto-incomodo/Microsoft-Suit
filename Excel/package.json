{
  "name": "@microsoft-suit/excel",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.stormgamesstudios.microsoft-suit.excel",
    "productName": "Excel - Office",
    "publish": [
      {
        "provider": "github",
        "owner": "acierto-incomodo",
        "repo": "microsoft-suit"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "assets/icon.ico",
      "differentialPackage": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64", "arm64", "armv7l"]
        },
        {
          "target": "deb",
          "arch": ["x64", "arm64", "armv7l"]
        }
      ],
      "icon": "assets/icon.png",
      "differentialPackage": true,
      "synopsis": "Microsoft Excel - Office Suite",
      "category": "Office"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "include": "installer.nsh",
      "differentialPackage": true
    },
    "appImage": {
      "differentialPackage": true
    },
    "deb": {
      "differentialPackage": true
    }
  }
}