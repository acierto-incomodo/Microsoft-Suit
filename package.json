{
  "name": "microsoft-suit",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "private": true,
  "workspaces": [
    "Excel",
    "PowerPoint",
    "Word"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "install:all": "npm install --workspaces",
    "install:workspaces": "npm install --workspaces",
    "ncu": "npx npm-check-updates -u --workspaces",
    "update:deps": "npx npm-check-updates -u --workspaces && npm install"
  },
